<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<link rel="stylesheet" href="~/css/NGMain.css" />

<div class="page-wrapper">

    <div class="top-header">
        <div class="header-left">
            <div class="title">MPCB SERIAL</div>
            <form method="post" asp-action="SearchMPCBSerial" class="search-form">
                <input type="text" name="mpcbSerial" placeholder="Enter Serial..." />
                <button type="submit">SEARCH</button>
            </form>
        </div>

        <div class="header-right">
            <button type="button" class="btn btn-orange action-btn" id="update_btn" data-bs-toggle="modal" data-bs-target="#updateModal">
                UPDATE MCB DATA
            </button>
            <button type="button" class="btn btn-orange action-btn" id="upload_btn" data-bs-toggle="modal" data-bs-target="#uploadModal">
                UPLOAD INPUT QTY
            </button>
            <button type="button" class="btn btn-orange action-btn" id="export_btn" data-bs-toggle="modal" data-bs-target="#exportModal">
                EXPORT
            </button>
        </div>
    </div>

    <div class="table-wrapper">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>MPCB SERIAL</th>
                    <th>MONTH</th>
                    <th>WEEK</th>
                    <th>DATE ENCOUNTERED</th>
                    <th>PART CODE</th>
                    <th>BOARD TYPE</th>
                    <th>PRODUCT SERIES</th>
                    <th>MODEL NAME</th>
                    <th>PRODUCT NAME</th>
                    <th>MACHINE SERIAL</th>
                    <th>DESTINATION</th>
                    <th>LINE</th>
                    <th>SHIFT</th>
                    <th>PROCESS ENCOUNTERED</th>
                    <th>MACHINE ERROR</th>
                    <th>PHENOMENON</th>
                    <th>ComboIC LOT</th>
                    <th>DRAM Vender</th>
                    <th>DRAM LOT</th>
                    <th>ROM0 Vendor</th>
                    <th>ROM0 Lot</th>
                    <th>ROM1 Vender</th>
                    <th>ROM1 Lot</th>
                    <th>Condition of MPCB</th>
                    <th>Defect Category</th>
                    <th>MPCB STATUS</th>
                    <th>CAUSE</th>
                    <th>DEFECT LOCATION</th>
                    <th>CAUSE CATEGORY</th>
                    <th>ROOT CAUSE</th>
                    <th>DATE CONDUCTED ICT/ FCT</th>
                    <th>ICT Result (Before 1st Replacement)</th>
                    <th>FCT Result (Before 1st Replacement)</th>
                    <th>CAUSE</th>
                    <th>DATE DELIVERED</th>
                    <th>DATE RETURNED</th>
                    <th>MACHINE ERROR</th>
                    <th>DATE CONDUCTED ICT/ FCT</th>
                    <th>1st Part Replacement</th>
                    <th>DATE REPAIR</th>
                    <th>ICT Result (After 1st Replacement)</th>
                    <th>FCT Result (After 1st Replacement)</th>
                    <th>CAUSE</th>
                    <th>DATE DELIVERED</th>
                    <th>DATE RETURNED</th>
                    <th>MACHINE ERROR</th>
                    <th>DATE CONDUCTED ICT/FCT</th>
                    <th>2nd Part Replacement</th>
                    <th>DATE REPAIR</th>
                    <th>ICT Result (After 2nd Replacement)</th>
                    <th>FCT Result (After 2nd Replacement)</th>
                    <th>CAUSE</th>
                    <th>DATE DELIVERED</th>
                    <th>DATE RETURNED</th>
                    <th>MACHINE ERROR</th>
                    <th>DATE CONDUCTED ICT/FCT</th>
                    <th>3rd Parts Replacement</th>
                    <th>DATE REPAIR</th>
                    <th>ICT Result (After 3rd Replacement)</th>
                    <th>FCT Result (After 3rdReplacement)</th>
                    <th>CAUSE</th>
                    <th>DATE DELIVERED</th>
                    <th>DATE RETURNED</th>
                    <th>REMARKS IF DISPOSE</th>
                    <th>COMBO IC MODEL</th>
                    <th>HAVE DAMAGE PINS?</th>
                    <th>DAMAGE SURFACE</th>
                    <th>WITH AUDIT FINDINGS?</th>
                    <th>PRT GOOD RATE</th>
                    <th>Motor Driver Lot</th>
                    <th>COUNT</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    @for (int i = 0; i < 71; i++)
                    {
                        <td><input type="text" /></td>
                    }
                </tr>
            </tbody>
        </table>
    </div>
</div>

<div class="modal fade" id="uploadModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal">
            <div class="modal-header">
                <h5 class="modal-title">IMPORT PRODUCTION INPUT QTY</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-action="UploadProdInputQty" enctype="multipart/form-data">

                    <label class="form-label">Input file location:</label>

                    <!-- Hidden real input -->
                    <input type="file" id="fileInput" name="file" hidden>

                    <!-- Custom UI -->
                    <div class="input-group mb-3">
                        <input type="text" id="fileName" class="form-control" placeholder="No file selected" readonly>
                        <button type="button" class="btn btn-secondary" onclick="document.getElementById('fileInput').click()">
                            Browse
                        </button>
                    </div>

                    <div class="d-flex justify-content-center mt-3">
                        <button type="submit" class="btn btn-success">IMPORT</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="exportModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content custom-modal">
            <div class="modal-header">
                <h5 class="modal-title">Do you want to Export MPCB Data?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-action="ExportData">
                    <div class="row g-2">

                        <!-- Existing Fields -->
                        <div class="col-md-6">
                            <label>By Time</label>
                            <select class="form-control" name="time">
                                <option>Shift</option>
                                <option>Week</option>
                                <option>Month</option>
                                <option>Year</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Start Date</label>
                            <input type="date" class="form-control" name="startDate">
                        </div>


                        <div class="col-md-6">
                            <label>Phenomenon</label>
                            <select class="form-control" name="phenomenon">
                                <option value="">-- Select --</option>
                                <option>Phenomenon 1</option>
                                <option>Phenomenon 2</option>
                            </select>
                        </div>
                        <!-- NEW FIELDS -->

                        <div class="col-md-6">
                            <label>End Date</label>
                            <input type="date" class="form-control" name="endDate">
                        </div>

                        <div class="col-md-6">
                            <label>Bare Board Type</label>
                            <select class="form-control" name="bareBoardType">
                                <option value="">-- Select --</option>
                                <option>Type A</option>
                                <option>Type B</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Model Name</label>
                            <select class="form-control" name="modelName">
                                <option value="">-- Select --</option>
                                <option>Model X</option>
                                <option>Model Y</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Production Process</label>
                            <select class="form-control" name="productionProcess">
                                <option value="">-- Select --</option>
                                <option>Process 1</option>
                                <option>Process 2</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label>Line</label>
                            <select class="form-control" name="line">
                                <option value="">-- Select --</option>
                                <option>Line 1</option>
                                <option>Line 2</option>
                            </select>
                        </div>

                    </div>

                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-primary">EXPORT</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="updateModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content custom-modal">
            <div class="modal-header">
                <h5 class="modal-title">WHAT DETAILS WILL YOU UPDATE?</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <form method="post" asp-action="UpdateMCBData">

                    <!-- OPTION 1 -->
                    <div class="form-check mb-2">
                        <input class="form-check-input" type="radio" name="updateType" value="info" checked>
                        <label class="form-check-label fw-bold">
                            UPDATE INFORMATION DATA
                        </label>
                        <div class="form-text ms-4">
                            Update parts lot, supplier, MCB standard and other needed information
                        </div>
                    </div>

                    <!-- OPTION 2 -->
                    <div class="form-check">
                        <input class="form-check-input" type="radio" name="updateType" value="condition">
                        <label class="form-check-label fw-bold">
                            UPDATE MPCB CONDITION
                        </label>
                        <div class="form-text ms-4">
                            Update actual condition of ongoing analysis MPCB
                        </div>
                    </div>

                    <div class="text-end mt-3">
                        <button type="submit" class="btn btn-primary">OK</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>