<!------------------- SUB PARTS ANALYSIS COMPLETED MODAL ------------------->
<div class="modal fade" id="modalSubPartsCompleted" tabindex="-1"
     data-bs-backdrop="static" data-bs-keyboard="false">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header subparts-completed-header">
        <h5 class="modal-title">UNIT ASSEMBLY / SUB-PARTS ANALYSIS</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p class="text-muted small">
          NOTE: Control Number is first column (“A”) in Machine Database Sheet. (Ex. 001)
        </p>

        <!-- CONTROL NUMBER -->
        <div class="mb-3">
          <label class="form-label">CONTROL NUMBER</label>
          <input type="text" id="sp_controlNumber" class="form-control" placeholder="001" />
        </div>

        <h6 class="fw-bold">MACHINE DETAILS</h6>

        <!-- Received Time & Time Analysis End -->
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">Received Time</label>
            <input type="datetime-local" id="sp_receivedTime" class="form-control" />
          </div>
          <div class="col">
            <label class="form-label">Time Analysis End</label>
            <input type="datetime-local" id="sp_timeAnalysisEnd" class="form-control" />
          </div>
        </div>

        <!-- Analysis Time & Analyzed by -->
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">Analysis Time</label>
            <input type="datetime-local" id="sp_analysisTime" class="form-control" />
          </div>
          <div class="col">
            <label class="form-label">Analyzed by</label>
            <input type="text" id="sp_analyzedBy" class="form-control" />
          </div>
        </div>

        <!-- Phenomenon & Initial Cause -->
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">Phenomenon</label>
            <input type="text" id="sp_phenomenon" class="form-control" />
          </div>
          <div class="col">
            <label class="form-label">Initial Cause</label>
            <input type="text" id="sp_initialCause" class="form-control" />
          </div>
        </div>

        <!-- Category & Process -->
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">Category</label>
            <input type="text" id="sp_category" class="form-control" />
          </div>
          <div class="col">
            <label class="form-label">Process</label>
            <input type="text" id="sp_process" class="form-control" />
          </div>
        </div>

        <!-- Line & Linestop Related? -->
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">Line</label>
            <input type="text" id="sp_line" class="form-control" />
          </div>
          <div class="col">
            <label class="form-label">Linestop Related?</label>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="sp_linestop" id="sp_linestopNo" value="No">
              <label class="form-check-label" for="sp_linestopNo">No</label>
            </div>
            <div class="form-check form-check-inline">
              <input class="form-check-input" type="radio" name="sp_linestop" id="sp_linestopYes" value="Yes">
              <label class="form-check-label" for="sp_linestopYes">Yes</label>
            </div>
          </div>
        </div>

        <hr>
        <h6 class="fw-bold">Sub Unit Assembly / Sub-Parts Analysis</h6>

        <!-- Analyze by (two dropdowns) -->
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">Analyze by</label>
            <select id="sp_analyzeByDropdown1" class="form-select">
              <option value="">-- Select --</option>
              <!-- Populate dynamically if needed -->
            </select>
          </div>
          <div class="col">
            <label class="form-label">&nbsp;</label>
            <select id="sp_analyzeByDropdown2" class="form-select">
              <option value="">-- Select --</option>
            </select>
          </div>
        </div>

        <!-- Defect Category (dropdown) -->
        <div class="mb-3">
          <label class="form-label">Defect Category</label>
          <select id="sp_defectCategory" class="form-select">
            <option value="">-- Select --</option>
            <!-- Populate dynamically if needed -->
          </select>
        </div>

        <!-- Sub Unit / Sub Part Name -->
        <div class="mb-3">
          <label class="form-label">Sub Unit / Sub Part Name</label>
          <input type="text" id="sp_subUnitPartName" class="form-control" />
        </div>

        <!-- Cause -->
        <div class="mb-3">
          <label class="form-label">Cause</label>
          <input type="text" id="sp_cause" class="form-control" />
        </div>

        <!-- Finish Analysis Date & Time -->
        <div class="mb-3">
          <label class="form-label">Finish Analysis Date &amp; Time</label>
          <input type="datetime-local" id="sp_finishAnalysisDateTime" class="form-control" />
        </div>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-primary" id="btnSaveSubParts">UPDATE</button>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">CANCEL</button>
      </div>
    </div>
  </div>
</div>
<div class="mb-3">
    <label class="form-label">MACHINE SERIAL</label>
    <input type="text" id="sp_machineSerial" class="form-control"
           placeholder="Scan or type machine serial..." />
</div>



