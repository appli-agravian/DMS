@{
    ViewData["Title"] = "User Management";
}

@* <link href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css" rel="stylesheet"> *@

<link rel="stylesheet" href="~/css/Access.css" />

<div class="page-container">

    <h2 class="page-title">@ViewData["Title"]</h2>
    <div class="spacer" style="height:5px;"></div>

<div class="custom-container mt-4">
    <div class="table-wrapper">
        <div class="table-responsive">
            <table id="userTable" class="table table-striped table-bordered align-middle">
                <thead class="table-dark">
                    <tr>
                        <th rowspan="2">Select</th>
                        <th rowspan="2">Members</th>
                        <th rowspan="2">ID Number</th>
                        <th rowspan="2">ADID</th>
                        <th rowspan="2">Email</th>
                        <th colspan="5" class="text-center">Module Authority</th>
                         <th rowspan="2">Actions</th>
                       
                    </tr>
                    <tr>
                        <th>Inline Monitoring</th>
                        <th>MPCB Database</th>
                        <th>Endorsement Email</th>
                        <th>User Management</th>
                        <th>Export</th>
                    </tr>
                </thead>

                <tbody>

                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="addUserModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">Account Details</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <div class="mb-3">
          <label class="form-label">Employee Number</label>
          <input id="empNumber" class="form-control" placeholder="Press Enter to auto-fill" />
        </div>
        <div class="mb-3">
          <label class="form-label">Full Name</label>
          <input id="fullName" class="form-control" readonly />
        </div>
        <div class="row mb-3">
          <div class="col">
            <label class="form-label">ADID</label>
            <input id="adid" class="form-control" readonly />
          </div>
          <div class="col">
            <label class="form-label">Department</label>
            <input id="email" class="form-control" readonly />
          </div>
           <div class="col">
            <label class="form-label">Section</label>
            <input id="email" class="form-control" readonly />

          <div class="mb-3">
          <label class="form-label">Email</label>
          <input id="fullName" class="form-control" readonly />
        </div>

        </div>
      </div>
      <div class="modal-footer">
        <button id="saveUser" class="btn btn-primary">SAVE</button>
        <button type="button" class="btn btn-danger" data-bs-dismiss="modal">CANCEL</button>
      </div>
    </div>
  </div>
</div>
</div>

@section Scripts {

    <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.13.6/js/dataTables.bootstrap5.min.js"></script>

    <script src="https://cdn.datatables.net/buttons/2.4.2/js/dataTables.buttons.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.bootstrap5.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.10.1/jszip.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/pdfmake.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdfmake/0.2.7/vfs_fonts.js"></script>

    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.4.2/js/buttons.print.min.js"></script>

    <script src="~/js/Access.js"></script>
   
}